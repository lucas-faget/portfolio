---
import { Button } from "./ui/button";
import { Link, GitBranch } from "lucide-react";
import MagicRings from "./MagicRings";
---

<div class="relative flex h-screen w-full items-center justify-center">
    <div class="absolute h-full w-full overflow-hidden">
        <MagicRings
            client:load
            color="#ffffff"
            colorTwo="#ffffff"
            ringCount={6}
            speed={1}
            attenuation={10}
            lineThickness={2}
            baseRadius={0.35}
            radiusStep={0.1}
            scaleRate={0.1}
            opacity={1}
            blur={0}
            noiseAmount={0.1}
            rotation={0}
            ringGap={1.5}
            fadeIn={0.7}
            fadeOut={0.5}
            followMouse={false}
            mouseInfluence={0.2}
            hoverScale={1.2}
            parallax={0.05}
            clickBurst={false}
        />
    </div>

    <div class="flex flex-col items-center gap-6">
        <p class="w-100 text-center text-6xl font-bold">Lucas Faget, web developer</p>
        <div class="flex gap-4">
            <Button className="rounded-full" size="lg">
                <Link />
                LinkedIn
            </Button>
            <Button className="rounded-full" size="lg" variant="secondary">
                <GitBranch />
                Github
            </Button>
        </div>
    </div>
</div>
